---
import { fedeData } from '../data/fede';
import { belenData } from '../data/belen';
import PersonTabs from '../components/PersonTabs.astro';
import DayGrid from '../components/DayGrid.astro';
import '../styles/global.css';

const people = [fedeData, belenData];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content="Plan de entrenamiento — Fede & Belén" />
    <meta name="theme-color" content="#1a1a1a" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <title>Gym Tracker · Fede & Belén</title>
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
  </head>
  <body>
    <header class="site-header">
      <div class="site-title">Gym Tracker</div>
      <PersonTabs people={people} />
    </header>

    <main>
      {people.map((person, i) => (
        <DayGrid days={person.days} personId={person.id} active={i === 0} />
      ))}
    </main>

    <script>
      // ── Tab switching ──────────────────────────────────────────
      document.querySelectorAll<HTMLButtonElement>('[data-tab-btn]').forEach(btn => {
        btn.addEventListener('click', () => {
          const target = btn.dataset.target!;

          // Update tabs
          document.querySelectorAll('[data-tab-btn]').forEach(b => {
            b.classList.remove('active');
            b.setAttribute('aria-selected', 'false');
          });
          btn.classList.add('active');
          btn.setAttribute('aria-selected', 'true');

          // Update panels
          document.querySelectorAll('.person-days').forEach(panel => {
            panel.classList.remove('active');
          });
          document.querySelector(`[data-person="${target}"]`)?.classList.add('active');
        });
      });

      // ── Accordion ─────────────────────────────────────────────
      const WORKER_URL = import.meta.env.PUBLIC_WORKER_URL ?? '';

      document.querySelectorAll<HTMLButtonElement>('.weight-save-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const person = btn.dataset.person!;
          const day = btn.dataset.day!;
          const exerciseIndex = Number(btn.dataset.exerciseIndex);

          const input = document.querySelector<HTMLInputElement>(
            `input[data-person="${person}"][data-day="${day}"][data-exercise-index="${exerciseIndex}"]`
          )!;
          const statusEl = btn.closest('.weight-row')!.querySelector<HTMLElement>('.weight-status')!;

          const weight = parseFloat(input.value);
          if (isNaN(weight) || weight < 0) {
            statusEl.textContent = 'Valor inválido';
            statusEl.className = 'weight-status error';
            return;
          }

          if (!WORKER_URL) {
            statusEl.textContent = 'Worker no configurado';
            statusEl.className = 'weight-status error';
            return;
          }

          btn.disabled = true;
          statusEl.textContent = 'Guardando...';
          statusEl.className = 'weight-status';

          try {
            const res = await fetch(WORKER_URL, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ person, day, exerciseIndex, weight }),
            });

            if (res.ok) {
              statusEl.textContent = '✓ Guardado';
              statusEl.className = 'weight-status ok';
              setTimeout(() => { statusEl.textContent = ''; statusEl.className = 'weight-status'; }, 3000);
            } else {
              const err = await res.text();
              statusEl.textContent = `Error: ${err}`;
              statusEl.className = 'weight-status error';
            }
          } catch {
            statusEl.textContent = 'Sin conexión';
            statusEl.className = 'weight-status error';
          } finally {
            btn.disabled = false;
          }
        });
      });

      // ── Accordion ─────────────────────────────────────────────
      document.querySelectorAll<HTMLButtonElement>('.exercise-summary').forEach(btn => {
        btn.addEventListener('click', () => {
          const item = btn.closest('.exercise-item')!;
          const isOpen = item.classList.toggle('open');
          btn.setAttribute('aria-expanded', String(isOpen));
        });
      });
    </script>
  </body>
</html>

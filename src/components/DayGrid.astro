---
import type { TrainingDay } from '../types/training';
import DayCard from './DayCard.astro';

interface Props {
  days: TrainingDay[];
  personId: string;
  active?: boolean;
}

const { days, personId, active = false } = Astro.props;
---

<div class:list={['person-days', { active }]} data-person={personId}>
  <div class="day-grid">
    {days.map((day) => (
      <DayCard day={day} personId={personId} />
    ))}
  </div>
</div>
